{
  "name": "slotty",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted, single-user scheduling app with Google Calendar integration.",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "prisma generate && prisma migrate deploy && bun --bun next dev",
    "build": "prisma generate && next build",
    "start": "prisma generate && prisma migrate deploy && bun --bun next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/unit tests/integration",
    "test:watch": "bun test --watch tests/unit tests/integration",
    "test:e2e": "bun run build && bun run tests/e2e/seed.ts && playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:load": "bun run tests/load/slots.ts",
    "audit:security": "bun run scripts/audit-security.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "bun run prisma/seed.ts",
    "key:generate": "bun run scripts/generate-encryption-key.ts",
    "cli": "bun run src/cli/index.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@lucia-auth/adapter-prisma": "^4.0.1",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.3",
    "googleapis": "^144.0.0",
    "isomorphic-dompurify": "^2.19.0",
    "jszip": "^3.10.1",
    "lucia": "^3.2.0",
    "lucide-react": "^1.14.0",
    "luxon": "^3.5.0",
    "marked": "^15.0.4",
    "next": "14.2.18",
    "next-themes": "^0.4.6",
    "oslo": "^1.2.1",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.3.8",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "nock": "^14.0.0-beta.6",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  },
  "trustedDependencies": [
    "@node-rs/argon2",
    "sharp",
    "unrs-resolver"
  ]
}
