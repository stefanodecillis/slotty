// Slotty data model.
// Phase 0 includes only the foundational tables (User, Job).
// Subsequent phases extend this schema additively via Prisma migrations.

generator client {
  provider        = "prisma-client-js"
  // "native" covers local dev (mac, linux). "linux-musl-openssl-3.0.x" is
  // for the Alpine 3.x runtime image where OpenSSL 3 is the default — without
  // it explicit, prisma generate produces only the "linux-musl" engine which
  // fails at runtime with "could not locate the Query Engine".
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = []
}

datasource db {
  provider = "sqlite"
  url      = env("SLOTTY_DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Single-user owner. Exactly one row exists in MVP.
// ─────────────────────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String   @map("password_hash")
  email         String
  displayName   String   @map("display_name")
  avatarPath    String?  @map("avatar_path")
  bio           String?
  timezone      String   @default("UTC")
  timezoneSet   Boolean  @default(false) @map("timezone_set")
  locale        String   @default("en")
  theme         String   @default("system") // light | dark | system
  seedColor     String   @default("#4F6CFF") @map("seed_color")
  weekStart     Int      @default(1) @map("week_start") // 0=Sunday, 1=Monday
  totpSecretEnc String?  @map("totp_secret_enc")
  totpEnabled   Boolean  @default(false) @map("totp_enabled")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions         Session[]
  schedules        Schedule[]
  eventTypes       EventType[]
  webhookEndpoints WebhookEndpoint[]
  backupCodes      BackupCode[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Lucia v3 sessions. Body fields populated in Phase 1.
// ─────────────────────────────────────────────────────────────
model Session {
  id        String   @id
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")

  user User @relation(references: [id], fields: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────
// Per-IP login attempt log used by rate limiter. Failed attempts
// drive an exponential backoff window; successful attempts let
// the limiter clear stale failures. Old rows pruned by a job.
// ─────────────────────────────────────────────────────────────
model LoginAttempt {
  id          String   @id @default(cuid())
  ip          String
  success     Boolean
  attemptedAt DateTime @default(now()) @map("attempted_at")

  @@index([ip, attemptedAt])
  @@map("login_attempts")
}

// ─────────────────────────────────────────────────────────────
// Availability: schedules, rules, and date overrides.
// Phase 4. Times are wall-clock minutes-from-midnight in the
// schedule's timezone; slot conversion happens in Phase 6.
// ─────────────────────────────────────────────────────────────

model Schedule {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  timezone  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  rules      ScheduleRule[]
  overrides  DateOverride[]
  eventTypes EventType[]

  @@index([userId])
  @@map("schedules")
}

model ScheduleRule {
  id          String @id @default(cuid())
  scheduleId  String @map("schedule_id")
  weekday     Int // 0 = Sunday, 6 = Saturday
  startMinute Int    @map("start_minute") // minutes from midnight, 0-1439
  endMinute   Int    @map("end_minute") // exclusive

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, weekday])
  @@map("schedule_rules")
}

model DateOverride {
  id          String   @id @default(cuid())
  scheduleId  String   @map("schedule_id")
  date        DateTime // store as midnight UTC of the calendar date
  isBlocked   Boolean  @default(false) @map("is_blocked")
  startMinute Int?     @map("start_minute")
  endMinute   Int?     @map("end_minute")
  source      String   @default("manual") // "manual" | "holiday-import"
  label       String? // for holidays
  createdAt   DateTime @default(now()) @map("created_at")

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date])
  @@index([scheduleId, date])
  @@map("date_overrides")
}

// ─────────────────────────────────────────────────────────────
// Persistent job queue (no Redis). Polled every 5 s by the
// in-process worker. See src/lib/jobs/.
// ─────────────────────────────────────────────────────────────
model Job {
  id          String   @id @default(cuid())
  kind        String
  runAt       DateTime @map("run_at")
  payloadJson String   @default("{}") @map("payload_json")
  attempts    Int      @default(0)
  status      String   @default("pending") // pending | running | done | failed
  lastError   String?  @map("last_error")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status, runAt])
  @@index([kind, status])
  @@map("jobs")
}

// ─────────────────────────────────────────────────────────────
// Phase 3 — Google Calendar integration.
// A connected Google account (refresh + access tokens stored
// encrypted at rest), the calendars it exposes, and a local
// mirror of busy events so slot computation never hits Google
// in the booking hot path.
// ─────────────────────────────────────────────────────────────
model ConnectedAccount {
  id              String    @id @default(cuid())
  provider        String // "google"
  googleUserEmail String    @map("google_user_email")
  accessTokenEnc  String    @map("access_token_enc")
  refreshTokenEnc String    @map("refresh_token_enc")
  scopes          String // space-delimited
  expiresAt       DateTime  @map("expires_at")
  status          String    @default("active") // active | needs_reauth | disconnected
  lastSyncedAt    DateTime? @map("last_synced_at")
  lastSyncError   String?   @map("last_sync_error")
  createdAt       DateTime  @default(now()) @map("created_at")

  calendars      Calendar[]
  destinationFor EventType[]
  bookings       Booking[]

  @@unique([provider, googleUserEmail])
  @@map("connected_accounts")
}

model Calendar {
  id                    String    @id @default(cuid())
  connectedAccountId    String    @map("connected_account_id")
  googleCalendarId      String    @map("google_calendar_id")
  name                  String
  description           String?
  timezone              String?
  backgroundColor       String?   @map("background_color")
  isPrimary             Boolean   @default(false) @map("is_primary")
  isBusySource          Boolean   @default(true) @map("is_busy_source")
  isDestinationEligible Boolean   @default(false) @map("is_destination_eligible")
  syncToken             String?   @map("sync_token")
  watchChannelId        String?   @map("watch_channel_id")
  watchResourceId       String?   @map("watch_resource_id")
  watchExpiresAt        DateTime? @map("watch_expires_at")
  lastIncrementalSyncAt DateTime? @map("last_incremental_sync_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  busyEvents       BusyEvent[]
  destinationFor   EventType[]

  @@unique([connectedAccountId, googleCalendarId])
  @@map("calendars")
}

model BusyEvent {
  id               String   @id @default(cuid())
  calendarId       String   @map("calendar_id")
  googleEventId    String   @map("google_event_id")
  startAt          DateTime @map("start_at")
  endAt            DateTime @map("end_at")
  status           String // "confirmed" | "tentative" | "cancelled"
  isAllDay         Boolean  @default(false) @map("is_all_day")
  transparency     String   @default("opaque") // "opaque" | "transparent"
  recurringEventId String?  @map("recurring_event_id")
  updatedAt        DateTime @updatedAt @map("updated_at")

  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@unique([calendarId, googleEventId])
  @@index([startAt, endAt])
  @@index([calendarId, startAt])
  @@map("busy_events")
}

// ─────────────────────────────────────────────────────────────
// Phase 5 — Event Types.
// Each EventType is a bookable offering the owner publishes.
// ─────────────────────────────────────────────────────────────
model EventType {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  title                 String
  slug                  String   @unique
  descriptionMd         String?  @map("description_md")
  color                 String   @default("#4F6CFF")
  hidden                Boolean  @default(false)
  durationMinutes       Int      @map("duration_minutes")
  destinationAccountId  String   @map("destination_account_id")
  destinationCalendarId String   @map("destination_calendar_id")
  locationKind          String   @map("location_kind") // google_meet | phone | in_person | custom_link
  locationValue         String?  @map("location_value")
  bufferBeforeMin       Int      @default(0) @map("buffer_before_min")
  bufferAfterMin        Int      @default(0) @map("buffer_after_min")
  minNoticeMin          Int      @default(60) @map("min_notice_min")
  bookingWindowDays     Int      @default(60) @map("booking_window_days")
  maxPerDay             Int?     @map("max_per_day")
  maxPerWeek            Int?     @map("max_per_week")
  maxGuests             Int      @default(3) @map("max_guests")
  slotIntervalMin       Int      @default(15) @map("slot_interval_min")
  scheduleId            String?  @map("schedule_id")
  passwordHash          String?  @map("password_hash")
  confirmationMd        String?  @map("confirmation_md")
  redirectUrl           String?  @map("redirect_url")
  sendReminders         Boolean  @default(true) @map("send_reminders")
  position              Int      @default(0)
  archived              Boolean  @default(false)
  inviteOnly            Boolean  @default(false) @map("invite_only")
  // True for EventTypes created via the "New one-time link" flow. These are
  // managed in a separate UI section and pruned after their single invite
  // is consumed (or expires/is revoked) plus a retention window.
  isOneTime             Boolean  @default(false) @map("is_one_time")
  hiddenGuestsJson      String   @default("[]") @map("hidden_guests_json") // JSON array of emails silently added to every booking
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  destinationAccount  ConnectedAccount    @relation(fields: [destinationAccountId], references: [id], onDelete: Restrict)
  destinationCalendar Calendar            @relation(fields: [destinationCalendarId], references: [id], onDelete: Restrict)
  schedule            Schedule?           @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  questions           EventTypeQuestion[]
  bookings            Booking[]
  invites             BookingInvite[]

  @@index([userId, archived, hidden])
  @@index([userId, isOneTime, archived])
  @@index([slug])
  @@map("event_types")
}

model EventTypeQuestion {
  id          String  @id @default(cuid())
  eventTypeId String  @map("event_type_id")
  label       String
  helperText  String? @map("helper_text")
  kind        String // text | textarea | select | checkbox | radio
  required    Boolean @default(false)
  optionsJson String? @map("options_json") // JSON array for select/radio: ["a","b"]
  position    Int     @default(0)

  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@index([eventTypeId, position])
  @@map("event_type_questions")
}

// ─────────────────────────────────────────────────────────────
// Phase 7 — Bookings.
// A confirmed booking row. The `googleEventId` is null for the brief window
// between local insert and Google insert; if Google insert fails we keep the
// local row with `needsSync=true` so the booker still gets a confirmation
// page and the admin can retry. `clientRequestId` provides idempotent replay.
// ─────────────────────────────────────────────────────────────
model Booking {
  id                   String    @id @default(cuid())
  eventTypeId          String    @map("event_type_id")
  googleAccountId      String    @map("google_account_id")
  googleCalendarId     String    @map("google_calendar_id")
  googleEventId        String?   @map("google_event_id") // null until Google insert succeeds
  startAt              DateTime  @map("start_at")
  endAt                DateTime  @map("end_at")
  status               String    @default("confirmed") // confirmed | cancelled | rescheduled
  bookerName           String    @map("booker_name")
  bookerEmail          String    @map("booker_email")
  bookerTimezone       String    @map("booker_timezone")
  additionalGuestsJson String    @default("[]") @map("additional_guests_json") // JSON array of email strings
  notes                String?
  answersJson          String    @default("{}") @map("answers_json") // map of questionId -> answer value
  cancelTokenHash      String    @map("cancel_token_hash") // sha256 of the cancel token
  rescheduleTokenHash  String    @map("reschedule_token_hash")
  meetingUrl           String?   @map("meeting_url") // for Google Meet (or custom_link copy, in_person address, phone, etc.)
  noShow               Boolean   @default(false) @map("no_show")
  clientRequestId      String?   @map("client_request_id") // idempotency
  needsSync            Boolean   @default(false) @map("needs_sync") // true if Google insert failed
  syncError            String?   @map("sync_error")
  createdAt            DateTime  @default(now()) @map("created_at")
  cancelledAt          DateTime? @map("cancelled_at")
  cancelReason         String?   @map("cancel_reason")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  eventType     EventType        @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  googleAccount ConnectedAccount @relation(fields: [googleAccountId], references: [id], onDelete: Restrict)
  history       BookingHistory[]
  invite        BookingInvite?   @relation("BookingInviteUse")

  @@unique([eventTypeId, clientRequestId]) // idempotency dedupe
  @@index([startAt, endAt])
  @@index([eventTypeId, status])
  @@index([status, startAt])
  @@map("bookings")
}

model BookingHistory {
  id          String   @id @default(cuid())
  bookingId   String   @map("booking_id")
  action      String // created | rescheduled | cancelled | no_show_marked | no_show_cleared
  payloadJson String   @default("{}") @map("payload_json") // before/after snapshots
  actor       String // "booker" | "owner" | "system"
  createdAt   DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@map("booking_history")
}

// ─────────────────────────────────────────────────────────────
// One-time booking invite links.
// The owner generates an invite for an EventType (typically `inviteOnly`)
// and shares the resulting `/i/<rawToken>` URL with one specific person.
// The raw token is shown to the admin exactly once at generation; only
// `sha256(rawToken)` is stored. The invite is atomically claimed inside
// the booking transaction — `usedAt` and `usedByBookingId` flip together
// and stay set even if the booking is later cancelled (regenerate to share again).
// ─────────────────────────────────────────────────────────────
model BookingInvite {
  id               String    @id @default(cuid())
  eventTypeId      String    @map("event_type_id")
  tokenHash        String    @unique @map("token_hash") // sha256(rawToken)
  note             String? // admin-only label e.g. "Sarah at Acme"
  expiresAt        DateTime? @map("expires_at")
  usedAt           DateTime? @map("used_at")
  usedByBookingId  String?   @unique @map("used_by_booking_id")
  revokedAt        DateTime? @map("revoked_at")
  hiddenGuestsJson String    @default("[]") @map("hidden_guests_json") // JSON array of emails silently added to the booking that consumes this invite
  createdAt        DateTime  @default(now()) @map("created_at")

  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  usedBy    Booking?  @relation("BookingInviteUse", fields: [usedByBookingId], references: [id], onDelete: SetNull)

  @@index([eventTypeId, usedAt])
  @@index([eventTypeId, revokedAt])
  @@map("booking_invites")
}

// ─────────────────────────────────────────────────────────────
// Phase 9 — Audit log.
// Best-effort log of owner actions for security auditing.
// ─────────────────────────────────────────────────────────────
model AuditLog {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  actor        String // "owner" | "system"
  action       String // login | logout | settings.update | event_type.create | etc.
  targetType   String?  @map("target_type")
  targetId     String?  @map("target_id")
  metadataJson String   @default("{}") @map("metadata_json")
  ip           String?
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// Phase 9 — Outgoing webhooks.
// Endpoints register URLs and event subscriptions; deliveries
// track each HTTP attempt with retry state.
// ─────────────────────────────────────────────────────────────
model WebhookEndpoint {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  url            String
  secretEnc      String   @map("secret_enc")
  eventTypesJson String   @map("event_types_json") // JSON array of event names
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId, active])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id           String    @id @default(cuid())
  endpointId   String    @map("endpoint_id")
  event        String
  payloadJson  String    @map("payload_json")
  status       String    @default("pending") // pending | delivered | failed
  attempts     Int       @default(0)
  lastError    String?   @map("last_error")
  responseCode Int?      @map("response_code")
  nextRetryAt  DateTime? @map("next_retry_at")
  deliveredAt  DateTime? @map("delivered_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([endpointId, createdAt])
  @@map("webhook_deliveries")
}

// ─────────────────────────────────────────────────────────────
// Runtime-editable settings keyed by a short identifier. Used as an
// override layer above process.env — see src/lib/site-url/store.ts.
// Today this only stores `publicUrl`; future runtime-mutable settings
// can claim additional keys without another migration.
// ─────────────────────────────────────────────────────────────
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ─────────────────────────────────────────────────────────────
// Phase 9 — TOTP backup codes.
// SHA256-hashed, single-use codes for 2FA recovery.
// ─────────────────────────────────────────────────────────────
model BackupCode {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  codeHash  String    @map("code_hash") // sha256
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("backup_codes")
}
