# ─────────────────────────────────────────────────────────────────
# Slotty environment variables
# Copy this file to `.env` and fill in the required values.
# Generate secrets with: bun run key:generate
# ─────────────────────────────────────────────────────────────────

# === REQUIRED ===

# The public URL where Slotty is reachable (no trailing slash)
SLOTTY_PUBLIC_URL=http://localhost:3000

# 32-byte base64-encoded key for AES-256-GCM (generate with `bun run key:generate`)
SLOTTY_ENCRYPTION_KEY=

# Secret used to sign session cookies (generate with `bun run key:generate`)
SLOTTY_SESSION_SECRET=

# SQLite default. For Postgres use postgresql://user:pass@host:5432/slotty
SLOTTY_DATABASE_URL="file:../data/slotty.db"

# === GOOGLE INTEGRATION (required for calendar features) ===

# Create at https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client (Web)
# Authorized redirect URI: ${SLOTTY_PUBLIC_URL}/api/admin/calendars/callback
SLOTTY_GOOGLE_CLIENT_ID=
SLOTTY_GOOGLE_CLIENT_SECRET=

# === EMAIL (required for confirmations + reminders) ===

SLOTTY_SMTP_HOST=
SLOTTY_SMTP_PORT=587
SLOTTY_SMTP_USER=
SLOTTY_SMTP_PASS=
SLOTTY_SMTP_FROM="Slotty <noreply@example.com>"

# === OPTIONAL ===

# debug | info | warn | error (default: info)
SLOTTY_LOG_LEVEL=info

# Cloudflare Turnstile (optional, leave blank to disable booking captcha)
SLOTTY_TURNSTILE_SITE_KEY=
SLOTTY_TURNSTILE_SECRET=

# Sentry DSN for error reporting (optional)
SLOTTY_SENTRY_DSN=

# Trust X-Forwarded-* headers from reverse proxy (default: true)
SLOTTY_TRUST_PROXY=true
